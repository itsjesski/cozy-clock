{
  "name": "cozy-clock",
  "version": "1.1.1",
  "description": "A customizable sit/stand, pomodoro, and generic timer desktop app with a cute, modular dashboard.",
  "type": "commonjs",
  "main": "dist-electron/main/main/index.js",
  "homepage": "./",
  "scripts": {
    "dev": "node scripts/dev-electron.js",
    "dev:vite": "vite",
    "dev:electron": "node scripts/dev-electron.js",
    "build": "npm run build:vite && npm run build:electron",
    "build:vite": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:electron": "npm run build:main && electron-builder",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "release": "node scripts/release.js",
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major"
  },
  "dependencies": {
    "electron-is-dev": "^3.0.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.1.1",
    "howler": "^2.2.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.10.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@electron/notarize": "^2.1.0",
    "@types/howler": "^2.2.12",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^8.54.0",
    "sharp": "^0.34.5",
    "terser": "^5.46.1",
    "typescript": "^5.3.0",
    "vite": "^5.4.21",
    "wait-on": "^7.2.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
